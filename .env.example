# Copy to .env and fill in your values. Never commit the real .env file.

# GCP project this tool monitors.
GCP_PROJECT=slawatch-live-demo

# Path to GCP credentials.
#
# Local dev (already configured via gcloud):
#   ADC file  : ~/.config/gcloud/application_default_credentials.json
#   Run once  : gcloud auth application-default login
#   Quota proj: slawatch-live-demo
#
# Docker: mount the ADC file into the container (see Dockerfile comment block).
GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcloud/application_default_credentials.json

# Monitored Cloud Run service (us-central1):
#   Service : slawatch-demo
#   URL     : https://slawatch-demo-hhbtgijqfq-uc.a.run.app
#   Config  : config.yaml -> targets[0]
